# ============================================
# AI/ML Daily Digest - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# AI PROVIDERS
# ============================================
# Choose which AI provider to use (groq or gemini)
AI_PROVIDER=groq

# Groq API (Primary)
# Sign up at: https://console.groq.com
GROQ_API_KEY=

# Gemini API (Backup)
# Sign up at: https://aistudio.google.com
GEMINI_API_KEY=

# ============================================
# DATABASE
# ============================================
# Supabase Project Settings
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# PUBLISHING CHANNELS
# ============================================
# Telegram Bot
# Create bot with @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Email via Resend
# Sign up at: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# ============================================
# MCP SERVERS (Will be filled after Week 2)
# ============================================
# Your custom MCP servers deployed to Prefect Horizon
RESEARCH_SERVER_URL=
COMMUNITY_SERVER_URL=
UTILITY_SERVER_URL=

# GitHub Personal Access Token
# Settings → Developer settings → Personal access tokens
GH_PAT_TOKEN=

# ============================================
# OPTIONAL DATA SOURCES
# ============================================
# Kaggle API (for datasets + competitions)
# Account → Settings → API → Create New API Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# Semantic Scholar API (optional, works without)
# Request at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenReview (for conference papers)
# Sign up at: https://openreview.net
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# ============================================
# LOGGING & DEVELOPMENT
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # or "human" for development
